{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_REF",
      "enabled": true
    },
    "obsidian": {
      "type": "remote",
      "url": "https://127.0.0.1:27124/mcp/",
      "headers": {
        "Authorization": "Bearer YOUR_OBSIDIAN_API_KEY"
      },
      "enabled": true
    }
  }
}
